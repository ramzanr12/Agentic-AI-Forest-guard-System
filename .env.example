# ─────────────────────────────────────────────────
#  Agentic AI Forest Guard — Environment Config
# ─────────────────────────────────────────────────

# API Keys
OPENWEATHER_API_KEY=your_openweather_api_key_here
NEWS_API_KEY=your_newsapi_key_here

# JWT
SECRET_KEY=forest_guard_super_secret_key_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Database
DATABASE_URL=sqlite+aiosqlite:///./database/forest_guard.db

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# Streamlit
STREAMLIT_PORT=8501

# Forest Config
FOREST_NAME=GreenShield Forest Reserve
FOREST_CENTER_LAT=11.4916
FOREST_CENTER_LON=76.9294
FOREST_AREA_KM2=1200

# Alert Thresholds
FIRE_RISK_THRESHOLD=70
POACHING_RISK_THRESHOLD=60
OVERSTAY_HOURS=8

# Report Paths
REPORTS_DIR=./reports
LOGS_DIR=./logs
